{
  "name": "@codelittinc/carbon-design-system",
  "version": "0.1.0",
  "description": "CarbonOS Design System — Refined Carbon. Shared React UI components and design tokens.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codelittinc/carbon-design-system.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src/styles"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button.d.ts",
      "import": "./dist/button.js"
    },
    "./styles": "./src/styles/theme.css"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build": "storybook build",
    "build-storybook": "storybook build",
    "build:lib": "tsup",
    "prepack": "pnpm run build:lib",
    "typecheck": "tsc --noEmit",
    "start": "node server.js"
  },
  "engines": {
    "node": "22.x"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "express": "^4.19.2",
    "lucide-react": "^1.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-docs": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@tailwindcss/vite": "^4.2.4",
    "@types/google.maps": "^3.64.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "i18next": "^23.11.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^14.1.2",
    "storybook": "^8.6.14",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "brace-expansion@>=2.0.0 <2.1.2": "2.1.2",
      "body-parser@<1.20.6": "1.20.6",
      "uuid@<11.1.1": "11.1.1"
    }
  }
}
